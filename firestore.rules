rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // --- Primitives ---
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- Default Deny ---
    match /{document=**} {
      allow read, write: if false;
    }

    // --- User Profiles ---
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && request.auth.uid == userId;

      match /savedListings/{listingId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    // --- Listings ---
    match /listings/{listingId} {
      function isOwner() {
        return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'owner';
      }

      allow read: if true;
      allow create: if isSignedIn() && isOwner();
      allow update, delete: if isSignedIn() && (resource.data.ownerId == request.auth.uid);
    }

    // --- Saved Items (Private Subcollection) ---
    match /users/{userId}/savedListings/{listingId} {
      function isValidSavedListing(data) {
        return data.keys().hasAll(['addedAt'])
          && data.keys().size() == 1
          && data.addedAt is number;
      }
      allow list: if isSignedIn() && request.auth.uid == userId;
      allow get: if isSignedIn() && request.auth.uid == userId && isValidId(listingId);
      allow create: if isSignedIn() && request.auth.uid == userId && isValidId(listingId) && isValidSavedListing(incoming());
      allow delete: if isSignedIn() && request.auth.uid == userId && isValidId(listingId);
    }

    // --- Favorite Owners (Private Subcollection) ---
    match /users/{userId}/favoriteOwners/{ownerId} {
      allow list: if isSignedIn() && request.auth.uid == userId;
      allow get: if isSignedIn() && request.auth.uid == userId && isValidId(ownerId);
      allow create: if isSignedIn() && request.auth.uid == userId && isValidId(ownerId);
      allow delete: if isSignedIn() && request.auth.uid == userId && isValidId(ownerId);
    }

    // --- Rental Requests ---
    match /rentalRequests/{requestId} {
      function isParticipant() {
        return isSignedIn() && (request.auth.uid == resource.data.ownerId || request.auth.uid == resource.data.renterId);
      }
      
      allow read: if isParticipant();
      allow create: if isSignedIn(); 
      allow update: if isParticipant();
      allow delete: if isSignedIn() && request.auth.uid == resource.data.renterId;
    }

    // --- Chat System ---
    match /chats/{chatId} {
      function isInChat() {
        return isSignedIn() && request.auth.uid in resource.data.participants;
      }
      function isInUpcomingChat() {
        return isSignedIn() && request.auth.uid in request.resource.data.participants;
      }
      
      allow read: if isInChat();
      allow create, update: if isSignedIn() && (isInChat() || isInUpcomingChat());

      match /messages/{messageId} {
        function chatParticipants() {
          return get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        }
        allow read: if isSignedIn() && chatParticipants().hasAny([request.auth.uid]);
        allow create: if isSignedIn() && chatParticipants().hasAny([request.auth.uid]) && incoming().senderId == request.auth.uid;
        allow update: if isSignedIn() && (
          (existing().senderId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['content', 'edited'])) ||
          (chatParticipants().hasAny([request.auth.uid]) && incoming().diff(existing()).affectedKeys().hasOnly(['read']))
        );
        allow delete: if isSignedIn() && existing().senderId == request.auth.uid;
      }
    }

    // --- WebRTC Video & Audio Signaling System ---
    match /calls/{callId} {
      function isCallParticipant() {
        return isSignedIn() && (
          request.auth.uid == resource.data.callerId || 
          request.auth.uid == resource.data.receiverId
        );
      }
      function isUpcomingCallParticipant() {
        return isSignedIn() && (
          request.auth.uid == request.resource.data.callerId || 
          request.auth.uid == request.resource.data.receiverId
        );
      }

      allow read: if isCallParticipant();
      allow create: if isSignedIn() && incoming().callerId == request.auth.uid;
      allow update, delete: if isSignedIn() && (isCallParticipant() || isUpcomingCallParticipant());

      match /candidates/{candidateId} {
        function callDoc() {
          return get(/databases/$(database)/documents/calls/$(callId)).data;
        }
        allow read, write: if isSignedIn() && (
          request.auth.uid == callDoc().callerId || 
          request.auth.uid == callDoc().receiverId
        );
      }
    }

    // --- Notifications ---
    match /notifications/{notificationId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn(); // Users can trigger notifications for others (e.g. on message)
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // --- Reviews ---
    match /users/{userId}/reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && request.auth.uid == resource.data.reviewerId;
    }

    // --- User Reports ---
    match /reports/{reportId} {
      allow read: if isSignedIn(); // Logged in users can see reports context or admins
      allow create: if isSignedIn() && incoming().reporterId == request.auth.uid;
      allow update, delete: if isSignedIn() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }
  }
}
